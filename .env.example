# ===============================
# AI Crime Analytics Platform
# Environment Template (.env.example)
# ===============================

# --------------------------------
# FRONTEND (Next.js)
# --------------------------------
NEXT_PUBLIC_APP_NAME=AI Crime Analytics Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
NEXT_PUBLIC_DEFAULT_THEME=dark

# --------------------------------
# BACKEND (FastAPI - prefixed)
# --------------------------------
CRIME_ANALYTICS_APP_NAME=AI Crime Analytics Backend
CRIME_ANALYTICS_ENVIRONMENT=development
CRIME_ANALYTICS_LOG_LEVEL=INFO

# Backend Routes and Origins
CRIME_ANALYTICS_API_PREFIX=/api
CRIME_ANALYTICS_ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Security
# REPLACE THIS WITH A UNIQUE SECRET KEY FOR PRODUCTION
CRIME_ANALYTICS_SECRET_KEY=YOUR_LONG_RANDOM_SECRET_KEY_HERE
CRIME_ANALYTICS_ACCESS_TOKEN_EXPIRE_MINUTES=1440
CRIME_ANALYTICS_ALGORITHM=HS256

# Paths (Update to your local absolute path if necessary)
CRIME_ANALYTICS_DATABASE_DIR=./Database
CRIME_ANALYTICS_CSV_FILENAME=India_Crime_Dataset_StateWise_2000_2025.csv

# --------------------------------
# OPTIONAL DEPLOYMENT
# --------------------------------
# PYTHONUNBUFFERED=1
